# ScoutFolio local setup
# 1) Copy this file: cp .env.example .env.local
# 2) Fill in every variable below
# 3) Install and run: pnpm install && pnpm dev
# 4) Open http://localhost:3000 and sign in with Google

# --- NextAuth (Auth.js v5) ---
# Random string for session encryption. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app. Use http://localhost:3000 for local dev.
# In production, set to your real origin (e.g. https://scoutfolio.example.com).
AUTH_URL=http://localhost:3000

# --- Google OAuth ---
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
# Add these Authorized redirect URIs (adjust host/port as needed):
#   http://localhost:3000/api/auth/callback/google
#   https://<your-production-domain>/api/auth/callback/google
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Anthropic API (direct, used by /api/extract and /api/discover)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# --- Vercel AI Gateway (model routing, e.g. Claude) ---
# Create a key in the Vercel dashboard and attach it to your project.
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# --- Vercel Blob (PDF uploads) ---
# Create a Blob store for the project, then set this token in the Vercel project
# or run: vercel env pull
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=
